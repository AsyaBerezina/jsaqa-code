{
    "root": true,
    "env": {
      "node": true,
      "es2021": true
    },
    "extends": ["eslint:recommended", "plugin:prettier/recommended"],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "script"
    },
    "rules": {
      "no-var": "error",
      "prefer-const": "error",
      "no-use-before-define": "error"
    }
  }